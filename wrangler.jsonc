{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "evidenceops-fixture",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "send_metrics": false,
  "assets": {
    "directory": "./site",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"],
  },
  "vars": {
    "EVIDENCEOPS_MODE": "fixture",
    "OPENAI_MODEL": "gpt-5.6-sol",
  },
  "ratelimits": [
    {
      "name": "NARRATIVE_RATE_LIMITER",
      "namespace_id": "11001",
      "simple": {
        "limit": 5,
        "period": 60,
      },
    },
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1,
  },
  "env": {
    "production": {
      "name": "evidenceops",
      "workers_dev": false,
      "routes": [
        {
          "pattern": "evidenceops.tmcoconsulting.com",
          "custom_domain": true,
        },
      ],
      "vars": {
        "EVIDENCEOPS_MODE": "openai",
        "OPENAI_MODEL": "gpt-5.6-sol",
      },
      "secrets": {
        "required": ["OPENAI_API_KEY"],
      },
      "ratelimits": [
        {
          "name": "NARRATIVE_RATE_LIMITER",
          "namespace_id": "11001",
          "simple": {
            "limit": 5,
            "period": 60,
          },
        },
      ],
    },
  },
}
